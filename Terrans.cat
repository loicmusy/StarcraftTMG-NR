    <profile name="Slugthrower" typeId="07ee-ef54-fbf7-5ca9" typeName="Rules (Assault Phase)" hidden="false" id="7c6b-c406-4107-6bc4">
      <characteristics>
        <characteristic name="Effect" typeId="97a6-bd65-3d58-17e9">When this Unit makes a Ranged Attack with a C-14 Rifle and the target is Within 8&quot;, that weapon gains ANTI-EVADE (1).</characteristic>
