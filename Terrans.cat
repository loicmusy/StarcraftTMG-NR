    <profile name="Freedom Fighters" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="7eea-7a20-dc9c-a25b">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">The Supply Value of all Friendly Units Within 8&quot; of this Unit cannot be reduced below 1 for Contesting Mission Markers and completing objectives.</characteristic>
