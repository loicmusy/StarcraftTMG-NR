    <profile name="Advanced Training" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="8866-2868-a335-d6ea">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">Once per Round, when a Friendly Support Unit activates a Special Ability that costs CP, resolve that ability with its CP cost reduced by 1 (to a minimum of 0). Do not Exhaust this card.</characteristic>
