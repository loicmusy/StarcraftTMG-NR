        <characteristic name="Rules" typeId="67f6-1351-2ec8-7fd5"/>
      </characteristics>
    </profile>
    <profile name="Medic" typeId="18be-d8b9-8024-4925" typeName="Unit" hidden="false" id="b5f9-612c-f91c-0ab9">
      <characteristics>
        <characteristic name="Shd" typeId="4301-e83c-7226-741a"/>
        <characteristic name="Spd" typeId="1b39-d395-b125-7ea9">4/7</characteristic>
        <characteristic name="Eva" typeId="bc5e-a9b9-f09d-8dec">5+</characteristic>
        <characteristic name="Arm" typeId="08b0-2471-8408-9222">5+</characteristic>
        <characteristic name="HP" typeId="e275-f946-72ee-4a48">2</characteristic>
        <characteristic name="Size" typeId="357b-9a74-5a55-800e">2</characteristic>
      </characteristics>
    </profile>
    <profile name="Life Support" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="8824-cc52-003f-bcb7">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">Use when another Friendly Biological Unit suffers Damage Within 4&quot;. Reduce the Total Damage before allocation by 1 for each model in this Unit that is Within 4&quot; of the damaged Unit.</characteristic>
        <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Reaction (1 CP)</characteristic>
      </characteristics>
    </profile>
    <profile name="Restoration" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="3a1f-ef04-eb69-1ce3">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">Use when a Friendly Unit Within 4&quot; receives a DEBUFF. Remove all DEBUFFS from it.</characteristic>
        <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Reaction (1 CP)</characteristic>
      </characteristics>
    </profile>
    <profile name="Medpack" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="dd9d-69b4-9b62-dff0">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">Select another Friendly Biological Unit Within 4&quot;. Resolve the HEAL (X) effect for the targeted Unit, where X is the number of models in this Unit that are Within 4&quot; of the target Unit.</characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active (1 CP)</characteristic>
      </characteristics>
    </profile>
    <profile name="Optical Flare" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="f828-28f2-f2b3-c4a4">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">Select one Enemy Unit Within 12&quot;. Until the End of the Round, apply DEBUFF Range (4) to that Unit’s Ranged Weapons. That Unit cannot benefit from LONG RANGE.</characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active (2 CP)</characteristic>
      </characteristics>
    </profile>
    <profile name="Advanced Medical Facilities" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="7c3f-b4da-f63e-54de">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">This Unit’s Supply Value counts as 0 when calculating the Supply Pool.</characteristic>
        <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Passive</characteristic>
      </characteristics>
    </profile>
    <profile name="A-13 Flash Grenade Launcher" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="15c2-89c4-9cba-ce59">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf"> Increase the Optical Flare special ability&apos;s Range to 16&quot;. </characteristic>
        <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Passive</characteristic>
      </characteristics>
    </profile>
    <profile name="Stabilizer Medpacks" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="19a8-8ad8-1be5-a6bd">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">When this Unit resolves a Life Support or Medpack ability, treat it as having 1 additional model Within Range for calculating that ability&apos;s effects.</characteristic>
        <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Passive</characteristic>
      </characteristics>
    </profile>
    <profile name="Goliath" typeId="18be-d8b9-8024-4925" typeName="Unit" hidden="false" id="efbb-82d6-961e-ef21">
      <characteristics>
        <characteristic name="Shd" typeId="4301-e83c-7226-741a"/>
        <characteristic name="Spd" typeId="1b39-d395-b125-7ea9">7</characteristic>
        <characteristic name="Eva" typeId="bc5e-a9b9-f09d-8dec"/>
        <characteristic name="Arm" typeId="08b0-2471-8408-9222">4+</characteristic>
        <characteristic name="HP" typeId="e275-f946-72ee-4a48">10</characteristic>
        <characteristic name="Size" typeId="357b-9a74-5a55-800e">3</characteristic>
      </characteristics>
    </profile>
    <profile name="Point Defense Laser" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="64d7-5e8b-1f19-55cb">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf"> When another Friendly Unit Within 4&quot; is targeted by a Ranged Attack without the INSTANT keyword, remove up to 2 dice from the Attack Pool. Then remove this Unit from the battlefield. </characteristic>
        <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Passive</characteristic>
      </characteristics>
    </profile>
    <profile name="Gliding" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="cbdc-39c2-6bc8-b9fc">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">This model has DISPLACEMENT. </characteristic>
        <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Passive</characteristic>
      </characteristics>
    </profile>
    <profile name="Structure" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="d3a4-0dbc-a379-e0fa">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">This Unit cannot be Activated in any Phase and cannot perform actions. Additionally, its Current Supply Value is treated as 0, and it can never Control or Contest Mission Markers, ignoring the standard Zero Supply Exception. This Unit cannot be a target of an ability, unless stated otherwise. </characteristic>
        <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Passive</characteristic>
      </characteristics>
    </profile>
    <profile name="Raiders Roll!" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="03f3-93b7-3de5-83b8">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e"> When this Unit is nominated to deploy from Reserves, it may resolve its Stimpack ability with the CP cost reduced by 1 (to a minimum of 0). </characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Passive</characteristic>
      </characteristics>
    </profile>
    <profile name="Rapid Reinforcements" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="19a8-73ca-085a-8f13">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e"> When this Unit is nominated to deploy from Reserves, it may resolve the PLACE (10) effect from another Friendly Unit. No model may be set Within 8&quot; of any Enemy model. This Unit&apos;s Activation ends. </characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Passive</characteristic>
      </characteristics>
    </profile>
    <profile name="Vehicle Plating" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="d08f-dc87-dfe6-1c5e">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">Use before a Friendly Mechanical Unit makes an Armour Roll. That Unit gains TOUGH (1) for this roll. </characteristic>
        <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Reaction</characteristic>
      </characteristics>
    </profile>
    <profile name="Vehicle Weapons" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="1d17-4b0d-bae8-ab0c">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">The active Mechanical Unit’s first Ranged Weapon used gain CRITICAL HIT (1). </characteristic>
        <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Active</characteristic>
      </characteristics>
    </profile>
    <profile name="Go! Go! Go!" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="1721-d5ac-ed20-9063">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">The active Biological Unit performs a 2&quot; Move action. This does not count towards its action limit. </characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active</characteristic>
      </characteristics>
    </profile>
    <profile name="Armed and Ready" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="a14c-438a-d801-1494">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">The active Biological Unit Deploys from any table edge that is not a player&apos;s Entry Edge. No model may be placed Within 10&quot; of any Enemy model. This ability cannot be used if another Friendly Biological Unit has already been Deployed this Round.</characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active</characteristic>
      </characteristics>
    </profile>
    <profile name="Let&apos;s Have a Blast!" typeId="07ee-ef54-fbf7-5ca9" typeName="Rules (Assault Phase)" hidden="false" id="41c9-fa52-8acc-949c">
      <characteristics>
        <characteristic name="Effect" typeId="97a6-bd65-3d58-17e9">The active Biological Unit’s first Ranged Weapon used gain ANTI-EVADE (1). </characteristic>
        <characteristic name="Cost" typeId="06d2-1c49-1cfc-44f5">Active</characteristic>
      </characteristics>
    </profile>
    <profile name="Strap in!" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="75b1-1bae-d4ed-6f26">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">The active, Unengaged Ground Unit is placed in Reserves instead of performing an action. </characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active</characteristic>
      </characteristics>
    </profile>
    <profile name="Ready For Dust-off" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="a9e2-61ea-5135-eea2">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">The active, Unengaged Ground Unit is placed in Reserves instead of performing an action. </characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active</characteristic>
      </characteristics>
    </profile>
    <profile name="Infantry Armor" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="0619-07ae-508d-440d">
      <characteristics>
        <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">Use before a Friendly Biological Unit makes an Armour Roll. That Unit gains TOUGH (1) for this roll. </characteristic>
        <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Reaction</characteristic>
      </characteristics>
    </profile>
    <profile name="Field Repair" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="5bb0-86b2-6f7a-3ced">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">The active Mechanical Unit resolves the HEAL (2) effect.</characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active</characteristic>
      </characteristics>
    </profile>
    <profile name="ComSat Station" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="5845-e43b-3538-295b">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">Select one table edge that is not a player’s Entry Edge. Until the End of the Round, Enemy Units cannot Deploy from that edge. </characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active</characteristic>
      </characteristics>
    </profile>
    <profile name="Scanner Sweep" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="90bb-e4f5-29a0-b0f3">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">Place a Faction Indicator anywhere on the battlefield. While Enemy Units are Within 6&quot; of this Faction Indicator, they lose HIDDEN. </characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active</characteristic>
      </characteristics>
    </profile>
    <profile name="Additional Supply Depots" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="fd83-0ea5-90c6-2f3d">
      <characteristics>
        <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">The active Unit’s Supply Value is improved by 1 for Controlling and Contesting Mission Markers and completing objectives.</characteristic>
        <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
