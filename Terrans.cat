    <profile name="Grenade - Frag" typeId="07ee-ef54-fbf7-5ca9" typeName="Rules (Assault Phase)" hidden="false" id="73e3-df9f-4cf5-d51b">
      <characteristics>
        <characteristic name="Effect" typeId="97a6-bd65-3d58-17e9">When this Unit makes a Ranged Attack with a C-14 Rifle and the target is Within 8&quot;, that weapon’s S Dice is replaced by D6.</characteristic>
