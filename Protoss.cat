        <profile name="Structure" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="e626-bfe0-877a-a685">
          <characteristics>
            <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">This Unit cannot be Activated in any Phase and cannot perform actions. Additionally, its Current Supply Value is treated as 0, and it can never Control or Contest Mission Markers, ignoring the standard Zero Supply Exception. This Unit cannot be a target of an ability, unless stated otherwise.</characteristic>
            <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Passive</characteristic>
          </characteristics>
        </profile>
        <profile name="Khalai Ingenuity" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="1f4e-b1be-8473-d7e2">
          <characteristics>
            <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">Once per Round, when a Friendly Unit Within 4&quot; of this Pylon uses a Special Ability that costs Psionic Energy, that ability’s PE cost is reduced by 1.</characteristic>
            <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Passive</characteristic>
          </characteristics>
        </profile>
        <profile name="Warp Conduit" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="5799-cd35-02ba-0029">
          <characteristics>
            <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">Once per Round, the controlling player may deploy a Ground Unit from Reserves using this Pylon base as the Entry Edge. This Unit&apos;s Activation ends.</characteristic>
            <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Passive</characteristic>
          </characteristics>
        </profile>
      </profiles>
