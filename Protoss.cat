          </characteristics>
        </profile>
        <profile name="Devastating Charge" typeId="07ee-ef54-fbf7-5ca9" typeName="Rules (Assault Phase)" hidden="false" id="a3cd-e8fe-aa96-41b3">
          <characteristics>
            <characteristic name="Effect" typeId="97a6-bd65-3d58-17e9">Immediately after this Unit completes a successful Charge, resolve the IMPACT (3) 4+ effect.</characteristic>
            <characteristic name="Cost" typeId="06d2-1c49-1cfc-44f5">Passive</characteristic>
          </characteristics>
