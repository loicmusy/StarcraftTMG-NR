      <profiles>
        <profile name="Pylon Warp-In" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="d158-0c1b-f5a7-a9c8">
          <characteristics>
            <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">If there is no Friendly Pylon on the battlefield, place a Friendly Pylon Unit anywhere on the GROUND LEVEL of the battlefield more than 10&quot; away from any Enemy model. This Round, the Pylon is not eligible to use its Special Abilities (excluding Structure).</characteristic>
            <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active</characteristic>
          </characteristics>
          <comment>Faction Card</comment>
        </profile>
        <profile name="Bound by the Khala" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="5c86-647f-9a78-ab74">
          <characteristics>
            <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">At the end of the active Unit’s Activation, select one other Friendly Unit eligible to Activate in the current Phase. Immediately Activate that Unit.</characteristic>
            <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active</characteristic>
          </characteristics>
          <comment>Faction Card</comment>
        </profile>
      </profiles>
    </selectionEntry>
