        <profile name="Titan Killer" typeId="f61d-0471-085d-248c" typeName="Rules (Combat Phase)" hidden="false" id="923b-ed1d-b1dc-1d9c">
          <characteristics>
            <characteristic name="Effect" typeId="b94b-6a13-1240-6b8b">When this Unit makes a Close Combat Attack, and the target is Size 3 or larger, the weapon’s Damage characteristic is treated as 2.</characteristic>
            <characteristic name="Cost" typeId="6f0c-b621-2f03-fe52">Passive</characteristic>
