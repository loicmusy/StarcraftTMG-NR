        <profile name="Twilight Blades Sweep" typeId="7b96-11fe-e87a-e61c" typeName="Combat Weapon" hidden="false" id="6e4c-e6fc-0c66-ab51">
          <characteristics>
            <characteristic name="Rng" typeId="f6d9-ff21-6fe9-b821">E</characteristic>
            <characteristic name="Tgt" typeId="0bf8-6c63-e593-8417">Ground</characteristic>
            <characteristic name="RoA" typeId="af32-03e6-6c32-3580">6</characteristic>
