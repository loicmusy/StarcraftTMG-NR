        <profile name="Precognition" typeId="f61d-0471-085d-248c" typeName="Rules (Combat Phase)" hidden="false" id="f9f4-7b66-51b4-ee09">
          <characteristics>
            <characteristic name="Effect" typeId="b94b-6a13-1240-6b8b">This Unit is eligible to make an Evade roll against all attacks targeting it.</characteristic>
            <characteristic name="Cost" typeId="6f0c-b621-2f03-fe52">Passive</characteristic>
          </characteristics>
        </profile>
