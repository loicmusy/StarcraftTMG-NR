      <profiles>
        <profile name="Mass Recall" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="4799-d1bc-6d70-9f2b">
          <characteristics>
            <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">Once per Game. Place a Faction Indicator anywhere on the battlefield. All Friendly Protoss Units Within 6&quot; of this Faction Indicator are removed from the battlefield and placed in Reserves.</characteristic>
            <characteristic name="Cost" typeId="e11e-d579-0142-8de4">Active</characteristic>
          </characteristics>
          <comment>Faction Card</comment>
        </profile>
        <profile name="Dae’Uhl" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="509f-666c-f99f-c763">
          <characteristics>
            <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">When a Friendly Unit receives Damage, reduce the Total Damage by 2 (to a minimum of 1).</characteristic>
            <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Reaction</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Khalai" hidden="false" id="41ab-8fa0-e055-c722">
