        <profile name="Source of Creep" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="66fd-58d6-af5e-15bb">
          <characteristics>
            <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">A Friendly or Enemy Ground Zerg Unit Within 6&quot; of this Unit, counts as being ON CREEP.</characteristic>
            <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Passive</characteristic>
          </characteristics>
        </profile>
        <profile name="Omega Network" typeId="a305-fb8b-8be3-f0fe" typeName="Rules (Any Phase)" hidden="false" id="ddeb-ec94-526e-fe55">
          <characteristics>
            <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">The base of the Omega Worm counts as an Entry Edge. Each Round, Friendly Units with a combined Supply cost of 2 or less may be Deployed via this Entry Edge. If a Friendly Leading model finishes a Move, Disengage, or Run action in base-to-base contact with the Omega Worm, the controlling player may remove that Unit from the battlefield and return it to Reserves.</characteristic>
            <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Passive</characteristic>
          </characteristics>
        </profile>
        <profile name="Omega Worm" typeId="18be-d8b9-8024-4925" typeName="Unit" hidden="false" id="9207-2282-2a03-5c67">
