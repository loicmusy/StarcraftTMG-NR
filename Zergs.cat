          <characteristics>
            <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">Use before a Friendly Unit makes an Evade Roll. Apply a +1 Modifier to that roll.</characteristic>
            <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Reaction</characteristic>
