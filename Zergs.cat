        <profile name="Rapid Burrowing" typeId="ec1d-63b8-de26-1894" typeName="Rules (Movement Phase)" hidden="false" id="24b3-1296-f334-e23e">
          <characteristics>
            <characteristic name="Effect" typeId="1c06-5502-fb5a-616e">Select one Friendly, Unengaged Ground Zerg Unit on the battlefield. That Unit gains the Burrowed Status, even if it has already been Activated this Round.</characteristic>
