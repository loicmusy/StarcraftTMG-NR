          <characteristics>
            <characteristic name="Effect" typeId="616e-c7be-abff-a2bf">While Enemy Units are Within 6&quot; of this Unit, they lose HIDDEN Status.</characteristic>
            <characteristic name="Cost" typeId="1696-5ea7-559b-bb8b">Passive</characteristic>
          </characteristics>
